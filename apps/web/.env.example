# Database
DATABASE_URL="postgresql://user:password@localhost:5432/pageforge"

# Better Auth
BETTER_AUTH_SECRET="your-secret-here-min-32-chars-long"
BETTER_AUTH_URL="http://localhost:3000"

# Email
EMAIL_FROM="noreply@example.com"
# Transport options: "console" (local dev) or "smtp" (production)
EMAIL_TRANSPORT="console"

# SMTP settings (required when EMAIL_TRANSPORT=smtp)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="user@example.com"
SMTP_PASS="your-smtp-password"

# S3-compatible object storage (MinIO locally, R2/S3 in production)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=pageforge-dev
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PUBLIC_BASE_URL=http://localhost:9000/pageforge-dev
S3_FORCE_PATH_STYLE=true

# Isolated serving origin — token signing secret (Phase 7)
# MUST be at least 32 bytes of random data in production.
# Generate: openssl rand -base64 32
# Used by lib/serve/token.ts to mint/verify ephemeral HMAC-SHA256 serve tokens.
SERVE_TOKEN_SECRET=test-secret-minimum-32-bytes-ok
